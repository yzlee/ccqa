# Copy to `.env` and fill in. NEVER commit your real .env — it's
# gitignored, but be careful not to override that.
#
# Optional: when set, the supervisor LLM calls (flow generator, judge,
# editor, report) go through the Anthropic SDK directly. When unset,
# they fall back to `claude -p` and reuse your signed-in `claude` CLI.
ANTHROPIC_API_KEY=

# Optional knobs
# CCQA_PORT=4317
# CCQA_HOST=127.0.0.1
# CCQA_DEFAULT_CODER=claude-code
# CCQA_JUDGE_MODEL=claude-sonnet-4-6
# CCQA_CODEX_CLI=codex
# CCQA_LOG_LEVEL=info
