{
  "name": "@ccqa/cli",
  "version": "0.1.3",
  "description": "LLM-driven QA harness \u2014 drives Claude Code / Codex / Kimi to test git projects from a natural-language flow. Includes the embedded server and bundled web UI.",
  "license": "MIT",
  "author": "yzlee",
  "homepage": "https://github.com/yzlee/ccqa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yzlee/ccqa.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/yzlee/ccqa/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "qa",
    "testing",
    "agent",
    "llm",
    "automation",
    "cli"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ccqa": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.20",
    "@anthropic-ai/sdk": "^0.40.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "kleur": "^4.1.5",
    "nanoid": "^5.0.7",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ccqa/server": "*",
    "@ccqa/shared": "*",
    "@ccqa/web": "*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}